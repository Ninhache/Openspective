# Copy to .env and adjust as needed. All variables are optional; defaults shown.

# Detoxify model variant: original | unbiased | multilingual
OPENSPECTIVE_MODEL=multilingual

# Redis connection URL. Caching degrades gracefully if Redis is unreachable.
OPENSPECTIVE_REDIS_URL=redis://redis:6379

# Cache TTL in seconds.
OPENSPECTIVE_CACHE_TTL=3600

# Log level: DEBUG | INFO | WARNING | ERROR
OPENSPECTIVE_LOG_LEVEL=INFO

# Dev mode: DEBUG logging + permissive CORS + Swagger docs. Leave 0 in production.
OPENSPECTIVE_DEV_MODE=0

# Optional Bearer-token auth. Comma-separated tokens; leave empty to disable auth
# (the default). When set, the analyze endpoint requires 'Authorization: Bearer <token>'.
OPENSPECTIVE_API_TOKENS=

# Optional rate limiting (Redis-backed). 0 disables it (default). When > 0, each
# client (token if present, else IP) may make at most this many requests per window.
OPENSPECTIVE_RATE_LIMIT=0
OPENSPECTIVE_RATE_LIMIT_WINDOW=60

# Default span-score threshold. When spanAnnotations is requested, spans scoring
# below this are omitted. A per-attribute scoreThreshold in the request overrides it.
OPENSPECTIVE_SCORE_THRESHOLD=0.0

# Uvicorn worker count (informational; set in your process manager).
OPENSPECTIVE_WORKERS=1
